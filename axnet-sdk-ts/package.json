{
  "name": "@axnetfun/axnet-sdk-ts",
  "version": "1.0.0",
  "description": "Stateless x402 Swap SDK for Solana Agents",
  "author": "Axnet",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "ts-node": "^10.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.98.4"
  }
}
