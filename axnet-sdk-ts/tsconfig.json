{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "lib": ["ES2022", "DOM"],
      "declaration": true,
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "moduleDetection": "force",
      "allowImportingTsExtensions": false,
      "outDir": "dist"
    },
    "include": ["src"]
  }